<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema base IPN/ESCOM -->
    <style name="Base.Theme.Escomextra" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ipn_guinda</item>
        <item name="colorPrimaryVariant">@color/ipn_guinda_dark</item>
        <item name="colorSecondary">@color/ipn_gold</item>
        <item name="colorSecondaryVariant">@color/ipn_gold_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/ipn_guinda_dark</item>
    </style>

    <style name="Theme.Escomextra" parent="Base.Theme.Escomextra"/>

    <!-- Estilo para botones primarios IPN -->
    <style name="Button.IPN" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/ipn_guinda</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Estilo para botones secundarios IPN -->
    <style name="Button.IPN.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/ipn_guinda</item>
        <item name="android:textColor">@color/ipn_guinda</item>
    </style>
</resources>
