<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Header IPN -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:background="@color/ipn_guinda">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BlueTube · IPN ESCOM"
                android:textSize="10sp"
                android:textColor="@color/ipn_gold"
                android:letterSpacing="0.15"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡 Servidor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Servidor detenido"
                android:textSize="11sp"
                android:textColor="@color/ipn_gold_light"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnVisible"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Visible"
            android:textSize="11sp"
            android:backgroundTint="@color/ipn_guinda_dark"
            android:textColor="@color/ipn_gold"
            android:strokeColor="@color/ipn_gold"
            android:layout_marginEnd="6dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnIniciar"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Iniciar"
            android:textSize="11sp"
            android:backgroundTint="@color/ipn_gold"
            android:textColor="@color/ipn_guinda_dark"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>

    <!-- WebView YouTube ocupa todo el espacio -->
    <WebView
        android:id="@+id/webViewYT"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Botón enviar con colores IPN -->
    <Button
        android:id="@+id/btnEnviarCliente"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="▶  ENVIAR ESTE VIDEO AL CLIENTE"
        android:textSize="14sp"
        android:backgroundTint="@color/ipn_guinda"
        android:textColor="@color/white"
        android:textStyle="bold"
        style="@style/Widget.MaterialComponents.Button"/>

</LinearLayout>
