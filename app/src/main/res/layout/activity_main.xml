<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BlueTube"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YouTube via Bluetooth"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="56dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona el modo de este dispositivo:"
        android:textSize="13sp"
        android:textColor="#CCCCCC"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnServidor"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="MODO SERVIDOR"
        android:textSize="15sp"
        android:backgroundTint="#4ECDC4"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Este dispositivo tiene Internet. Recibe peticiones del cliente via Bluetooth."
        android:textSize="11sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnCliente"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="MODO CLIENTE"
        android:textSize="15sp"
        android:backgroundTint="#16213E"
        android:textColor="#4ECDC4"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Este dispositivo NO tiene Internet. Busca y reproduce videos a traves del servidor."
        android:textSize="11sp"
        android:textColor="#666666"
        android:gravity="center"/>

</LinearLayout>
